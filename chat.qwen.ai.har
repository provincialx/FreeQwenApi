esktop .chat-content .chat-left-panel .chat-left .chat-input .input-container textarea{flex:1;padding:12px;border:1px solid #d0d0d0;border-radius:8px;resize:none;font-size:14px;line-height:1.5;min-height:60px;max-height:120px;font-family:inherit}.chat-layout.chat-desktop .chat-content .chat-left-panel .chat-left .chat-input .input-container textarea:focus{outline:none;border-color:#007bff;box-shadow:0 0 0 2px #007bff40}.chat-layout.chat-desktop .chat-content .chat-left-panel .chat-left .chat-input .input-container .send-btn{padding:12px 24px;background-color:#007bff;color:#fff;border:none;border-radius:8px;cursor:pointer;font-size:14px;font-weight:500;transition:background-color .2s ease;white-space:nowrap}.chat-layout.chat-desktop .chat-content .chat-left-panel .chat-left .chat-input .input-container .send-btn:hover{background-color:#0056b3}.chat-layout.chat-desktop .chat-content .chat-left-panel .chat-left .chat-input .input-container .send-btn:disabled{background-color:#ccc;cursor:not-allowed}.chat-layout.chat-desktop .chat-content .panel-resize-handle{width:6px;background-color:#f0f0f0;cursor:col-resize;position:relative;transition:background-color .2s ease}.chat-layout.chat-desktop .chat-content .panel-resize-handle:hover{background-color:#007bff}.chat-layout.chat-desktop .chat-content .panel-resize-handle:after{content:\"\";position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:2px;height:40px;background-color:#ccc;border-radius:1px}.chat-layout.chat-desktop .chat-content .panel-resize-handle:hover:after{background-color:#fff}.chat-layout.chat-desktop .chat-content .chat-right-panel .chat-right{height:100%;display:flex;flex-direction:column}.chat-layout.chat-desktop .chat-content .chat-right-panel .chat-right .reference-header{padding:16px 20px;border-bottom:1px solid #e0e0e0;background-color:#fff}.chat-layout.chat-desktop .chat-content .chat-right-panel .chat-right .reference-header h3{margin:0 0 4px;color:#333;font-size:16px;font-weight:600}